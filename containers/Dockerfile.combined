# Combined Agent Server GUI + Automation Service — self-hosted image
#
# This image bundles everything needed for local/self-hosted deployments:
# - Agent Server GUI (conversation interface) at /
# - Automation service (scheduler, dispatcher, API) at /automations, /api/automation
# - Agent server (shared by both GUI and automations)
# - SQLite database (no external database required)
#
# Architecture:
# - Nginx on port 8000 (reverse proxy)
# - Agent Server on port 3002 (conversations + automation runs)
# - Automation Service on port 8001 (automation API)
#
# The agent-server-gui connects directly to agent-server, eliminating the need
# for the full OpenHands app server. This is simpler and more lightweight.
#
# Usage:
#   docker build -f containers/Dockerfile.combined -t openhands-local .
#   docker run -p 8000:8000 \
#     -v ~/.openhands:/root/.openhands \
#     -v ./data:/data \
#     -e LLM_MODEL=anthropic/claude-sonnet-4-20250514 \
#     -e LLM_API_KEY=sk-ant-... \
#     openhands-local

# ---- Stage 1: Build Agent Server GUI ----
FROM node:22-slim AS gui-frontend
WORKDIR /build

# Clone agent-server-gui repo
# Pin to a specific commit/branch for reproducibility
ARG AGENT_SERVER_GUI_REF=fix/version-fallback-to-sdk-version
RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates && \
    git clone --branch ${AGENT_SERVER_GUI_REF} --depth 1 https://github.com/OpenHands/agent-server-gui.git . && \
    rm -rf .git && \
    apt-get purge -y git && apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

# Install dependencies and build
RUN npm ci && npm run build

# Output is in /build/build/

# ---- Stage 2: Build Automation frontend ----
FROM node:24-slim AS automation-frontend
WORKDIR /frontend
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ .
# Build with base path for /automations subpath
ENV VITE_BASE_PATH=/automations
RUN npm run build

# ---- Stage 3: Final combined image ----
# Note: We install agent-server from branch in the final image instead of using
# the pre-built binary, because we need the feat/settings-persistence branch
# for /api/settings endpoints.
FROM python:3.13-slim

WORKDIR /app

LABEL org.opencontainers.image.title="OpenHands Local (GUI + Automations)"
LABEL org.opencontainers.image.description="Self-contained OpenHands with agent-server-gui, automations, and embedded agent server"
LABEL org.opencontainers.image.source="https://github.com/OpenHands/automation"

# Install system dependencies
# tmux is required for agent-server local runtime
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        supervisor \
        nginx \
        libpq-dev \
        procps \
        tmux \
        curl \
        git \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# ---- Install agent-server from SDK branch ----
# Using feat/settings-persistence branch for /api/settings endpoints
ARG SDK_REF=feat/settings-persistence
RUN pip install --no-cache-dir \
    "openhands-agent-server @ git+https://github.com/OpenHands/software-agent-sdk.git@${SDK_REF}#subdirectory=openhands-agent-server" \
    "openhands-sdk @ git+https://github.com/OpenHands/software-agent-sdk.git@${SDK_REF}#subdirectory=openhands-sdk" \
    "openhands-tools @ git+https://github.com/OpenHands/software-agent-sdk.git@${SDK_REF}#subdirectory=openhands-tools" \
    "openhands-workspace @ git+https://github.com/OpenHands/software-agent-sdk.git@${SDK_REF}#subdirectory=openhands-workspace" \
    libtmux

# Create wrapper script for agent-server (the package entry point is 'agent-server')
RUN echo '#!/bin/bash\nexec agent-server "$@"' > /usr/local/bin/openhands-agent-server && \
    chmod +x /usr/local/bin/openhands-agent-server

# ---- Create venv for Automation Service ----
RUN python3 -m venv /app/automation-venv && \
    /app/automation-venv/bin/pip install --upgrade pip

# Copy automation service source code
COPY pyproject.toml /app/automation-src/pyproject.toml
COPY README.md /app/automation-src/README.md
COPY automation/ /app/automation-src/automation/
COPY migrations/ /app/automation-src/migrations/
COPY alembic.ini /app/automation-src/

# Install automation service in its venv
RUN cd /app/automation-src && \
    /app/automation-venv/bin/pip install --no-cache-dir .

# Copy built frontends
COPY --from=gui-frontend /build/build /app/gui-frontend
COPY --from=automation-frontend /frontend/build /app/automation-frontend

# Copy configuration files
COPY containers/nginx.conf /etc/nginx/nginx.conf
COPY containers/supervisord.combined.conf /etc/supervisor/supervisord.conf
COPY containers/entrypoint.combined.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Create directories for data persistence
RUN mkdir -p /data /workspace /tmp/openhands-sandboxes && \
    chmod 755 /data /workspace /tmp/openhands-sandboxes

# Remove default nginx site
RUN rm -f /etc/nginx/sites-enabled/default

# ---- Environment Configuration ----

# Automation service configuration  
ENV AUTOMATION_AGENT_SERVER_URL=http://localhost:3002
ENV AUTOMATION_DB_URL=sqlite+aiosqlite:////data/automations.db
ENV AUTOMATION_BASE_URL=http://localhost:8000
ENV AUTOMATION_WORKSPACE_BASE=/workspace
ENV AUTOMATION_FRONTEND_DIR=/app/automation-frontend

# Local file storage for tarballs
ENV FILE_STORE=local
ENV LOCAL_STORAGE_PATH=/data/storage

# Agent server port (shared by GUI and automations)
ENV AGENT_SERVER_PORT=3002

# Volumes for data persistence
VOLUME /data
VOLUME /workspace

# Expose nginx (main entry point)
EXPOSE 8000

# Health check via agent-server
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:3002/health || exit 1

ENTRYPOINT ["/entrypoint.sh"]
CMD ["supervisord", "-c", "/etc/supervisor/supervisord.conf"]
